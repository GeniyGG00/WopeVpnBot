# Telegram Bot Token (получи у @BotFather)
BOT_TOKEN=your_bot_token_here

# Твой Telegram ID (узнай у @userinfobot)
ADMIN_ID=123456789

# Supabase (бесплатная БД - https://supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# URL твоего Cloudflare Worker
WORKER_URL=https://your-worker.workers.dev

# ЮKassa токен (необязательно - если не указан, будет ручная оплата)
# Получить на https://yookassa.ru
YOOKASSA_TOKEN=your_yookassa_token_here
